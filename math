// ── HELPERS ───────────────────────────────────────────
function explainQuestion(q){
  const t=q.q.toLowerCase();
  if(t.includes("round"))return"5 or more rounds up, 4 or less stays down.";
  if(t.includes("expanded"))return"Expanded form breaks a number into each digit's value.";
  if(t.includes("compare")||t.includes("greater")||t.includes("smaller")||t.includes("largest")||t.includes("smallest"))return"Compare from the biggest place value first.";
  if(t.includes("array")||t.includes("rows"))return"Arrays show equal rows and columns for multiplication.";
  if(t.includes("division")||t.includes("÷")||t.includes("shared"))return"Division means sharing equally into equal groups.";
  if(t.includes("fact famil"))return"Fact families show connected × and ÷ with the same numbers.";
  if(t.includes("groups of")||t.includes("×")||t.includes("multiplication"))return"Multiplication is repeated addition with equal groups.";
  if(t.includes("+")||t.includes("addition"))return"Add by place value: ones, then tens, then hundreds.";
  if(t.includes("place")||t.includes("value")||t.includes("hundreds")||t.includes("tens")||t.includes("thousands"))return"Place value tells what a digit is worth based on its position.";
  return"Think about the math model from this lesson and try again.";
}

function normalizeAnswer(v){
  return String(v).toLowerCase().replace(/,/g,"").replace(/\s*\+\s*/g,"+").replace(/\s+/g," ").trim();
}

// FIX 1: MCQ answer matching — find index by value, fallback to 0
function normalizeQuestion(q){
  if(q.type==="multiple_choice"){
    const idx=q.options.findIndex(o=>normalizeAnswer(o)===normalizeAnswer(q.answer));
    return{type:"mcq",text:q.q,emoji:"",choices:q.options,answer:idx<0?0:idx,hint:explainQuestion(q)};
  }
  return{type:"typed",text:q.q,emoji:"",answer:String(q.answer),hint:explainQuestion(q)};
}

function buildUnit(rawUnit,id,title,description){
  return{
    id,title,description,
    color:"var(--primary)",
    lessons:rawUnit.lessons.map((l,i)=>({
      id:l.lessonId,
      title:l.title,
      emoji:l.icon||"📖",
      xp:25+i*5,
      questions:l.questions.map(normalizeQuestion)
    }))
  };
}

