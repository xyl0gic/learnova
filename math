<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Learnova - Grade 3</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#F5F1E6;--card:#FFFFFF;--text:#0F2A1D;--muted:#4F7C6A;--primary:#0F2A1D;--primary-dark:#07150E;--accent:#D6B25E;--accent-dark:#B8933D;--secondary:#4F7C6A;--secondary-dark:#315545;--border:rgba(15,42,29,.15);--border-d:rgba(15,42,29,.28);--success:#4F7C6A;--success-pale:#E4EFE5;--danger:#D36135;--danger-pale:#FBE4DA;--warning:#D6B25E;--warning-pale:#F6E9C5;--ink:var(--text);--ink-soft:var(--muted);--ink-muted:rgba(15,42,29,.48);--white:var(--card);--green:var(--primary);--green-d:var(--primary-dark);--green-pale:var(--success-pale);--blue:var(--secondary);--blue-d:var(--secondary-dark);--blue-pale:#E5F0EC;--red:var(--danger);--red-d:#A84325;--red-pale:var(--danger-pale);--orange:var(--accent);--orange-pale:var(--warning-pale);--purple:var(--secondary);--purple-pale:#E8EFEA;--gold:var(--accent)}
[data-theme="ink"]{--bg:#EEF2F6;--card:#FFFFFF;--text:#172033;--muted:#59677E;--primary:#172033;--primary-dark:#0A0F19;--accent:#5271FF;--accent-dark:#3651C8;--secondary:#3D7EA6;--secondary-dark:#255575;--border:rgba(23,32,51,.14);--border-d:rgba(23,32,51,.3);--success:#3D7EA6;--success-pale:#E0EDF5;--danger:#B94A48;--danger-pale:#F7DEDD;--warning:#D8A545;--warning-pale:#F7EBCF;--ink:var(--text);--ink-soft:var(--muted);--ink-muted:rgba(23,32,51,.48);--white:var(--card);--green:var(--primary);--green-d:var(--primary-dark);--green-pale:var(--success-pale);--blue:var(--accent);--blue-d:var(--accent-dark);--blue-pale:#E4E9FF;--red:var(--danger);--red-d:#8A302E;--red-pale:var(--danger-pale);--orange:var(--warning);--orange-pale:var(--warning-pale);--purple:var(--secondary);--purple-pale:#E0EDF5;--gold:var(--accent)}
[data-theme="neon"]{--bg:#080A12;--card:#111827;--text:#F4F7FB;--muted:#A7B0C0;--primary:#7CFFCB;--primary-dark:#30B989;--accent:#FFE66D;--accent-dark:#D1B743;--secondary:#79A7FF;--secondary-dark:#4B72CC;--border:rgba(244,247,251,.16);--border-d:rgba(244,247,251,.32);--success:#7CFFCB;--success-pale:#17382F;--danger:#FF6B6B;--danger-pale:#3A1E27;--warning:#FFE66D;--warning-pale:#3A3320;--ink:var(--text);--ink-soft:var(--muted);--ink-muted:rgba(244,247,251,.5);--white:var(--card);--green:var(--primary);--green-d:var(--primary-dark);--green-pale:var(--success-pale);--blue:var(--secondary);--blue-d:var(--secondary-dark);--blue-pale:#1A2946;--red:var(--danger);--red-d:#C74848;--red-pale:var(--danger-pale);--orange:var(--accent);--orange-pale:var(--warning-pale);--purple:var(--secondary);--purple-pale:#1A2946;--gold:var(--accent)}
body{font-family:"Nunito","Segoe UI",system-ui,sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;overflow-x:hidden}
.screen{display:none;min-height:100vh;flex-direction:column;align-items:center;justify-content:center;padding:1.5rem}.screen.active{display:flex}
#screen-onboard,#screen-summary{background:linear-gradient(160deg,var(--bg) 0%,var(--blue-pale) 100%)}
.onboard-logo{font-size:52px;margin-bottom:.5rem}
.onboard-title{font-size:clamp(28px,5vw,42px);font-weight:900;text-align:center;line-height:1.15;margin-bottom:.5rem}
.onboard-title em{color:var(--green);font-style:normal}
.onboard-sub{font-size:16px;color:var(--ink-soft);text-align:center;max-width:360px;margin-bottom:2.5rem;line-height:1.6}
.name-input-wrap{display:flex;flex-direction:column;gap:12px;width:100%;max-width:340px;margin-bottom:2rem}
.name-input-wrap label{font-weight:700;font-size:15px}
.name-input,.avatar-select{padding:14px 18px;border:2px solid var(--border-d);border-radius:16px;font-family:inherit;font-size:16px;font-weight:600;outline:none;background:var(--white);color:var(--ink)}
.name-input:focus,.avatar-select:focus{border-color:var(--blue)}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:14px 28px;border-radius:16px;border:none;font-family:inherit;font-size:16px;font-weight:800;cursor:pointer;transition:transform .1s,box-shadow .1s;text-decoration:none}
.btn:active{transform:translateY(3px)!important;box-shadow:0 1px 0!important}
.btn-green{background:var(--green);color:var(--card);box-shadow:0 4px 0 var(--green-d)}
.btn-green:hover{opacity:.92}
.btn-blue{background:var(--blue);color:var(--card);box-shadow:0 4px 0 var(--blue-d)}
.btn-outline{background:var(--white);color:var(--ink);border:2px solid var(--border-d);box-shadow:0 4px 0 var(--border-d)}
.btn-lg{padding:16px 36px;font-size:18px;border-radius:24px;width:100%;max-width:340px}
.btn-disabled{opacity:.45;cursor:not-allowed;pointer-events:none}
#screen-map{background:linear-gradient(180deg,var(--bg) 0%,var(--blue-pale) 100%);justify-content:flex-start;padding-top:0}
.map-header{width:100%;background:var(--white);border-bottom:2px solid var(--border);padding:1rem 1.5rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.map-logo{font-weight:900;font-size:20px;color:var(--green)}.map-logo span{color:var(--ink)}
.streak-badge,.xp-badge{display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:100px;font-size:14px;font-weight:700}
.streak-badge{background:var(--orange-pale);color:var(--text)}.xp-badge{background:var(--purple-pale);color:var(--text)}
.map-body{width:100%;max-width:420px;padding:2rem 1rem 4rem;display:flex;flex-direction:column;align-items:center}
.unit-header-card{width:100%;border-radius:24px;padding:1.5rem;margin-bottom:1.5rem;text-align:center}
.unit-header-card h2{font-size:22px;font-weight:900;color:var(--card);margin-bottom:4px}
.unit-header-card p{font-size:14px;color:rgba(255,255,255,.9)}
.map-path{display:flex;flex-direction:column;align-items:center;width:100%}
.map-node-wrap{display:flex;flex-direction:column;align-items:center}
.map-connector{width:4px;height:28px;border-radius:4px}
.mc-done{background:var(--green)}.mc-locked{background:var(--border-d)}
.map-node{width:72px;height:72px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;cursor:pointer;transition:transform .15s;border:none;font-family:inherit}
.map-node:not(.locked):hover{transform:scale(1.08)}.map-node:not(.locked):active{transform:scale(.95)}
.node-done{background:var(--green);box-shadow:0 5px 0 var(--green-d);color:var(--card)}
.node-active{background:var(--blue);box-shadow:0 5px 0 var(--blue-d);color:var(--card);animation:pulse 2s infinite}
.node-locked{background:var(--border);box-shadow:0 5px 0 var(--border-d);color:var(--ink-muted);cursor:not-allowed}
@keyframes pulse{0%,100%{box-shadow:0 5px 0 var(--blue-d)}50%{box-shadow:0 5px 14px rgba(0,0,0,.2),0 5px 0 var(--blue-d)}}
.node-label{font-size:12px;font-weight:700;color:var(--ink-soft);margin-top:6px;text-align:center;max-width:100px;line-height:1.3}
.unit-complete-banner{border-radius:24px;padding:1.5rem;text-align:center;width:100%;margin-top:2rem}
.unit-complete-banner h3{font-size:20px;font-weight:900;margin-bottom:4px}
.unit-complete-banner p{font-size:14px;color:var(--ink-soft);margin-bottom:1rem}
.profile-header{display:flex;align-items:center;gap:14px;padding:16px;background:var(--primary);color:var(--bg);border-radius:14px;width:100%;max-width:420px;margin-bottom:18px;box-shadow:0 6px 0 var(--primary-dark)}
.avatar{font-size:34px;background:rgba(255,255,255,.12);width:56px;height:56px;display:flex;align-items:center;justify-content:center;border-radius:14px;flex-shrink:0}
.profile-text h2{margin:0;font-size:18px;line-height:1.2}.profile-text p{margin:2px 0 0;font-size:12px;opacity:.75}
#screen-lesson{background:var(--bg);justify-content:flex-start;padding:0}
.lesson-topbar{width:100%;background:var(--white);border-bottom:2px solid var(--border);padding:1rem 1.5rem;display:flex;align-items:center;gap:1rem;position:sticky;top:0;z-index:50}
.back-btn{background:none;border:none;cursor:pointer;font-size:22px;color:var(--ink-soft);padding:4px;line-height:1;border-radius:8px}
.progress-bar-outer{flex:1;height:14px;background:var(--border);border-radius:100px;overflow:hidden}
.progress-bar-inner{height:100%;background:var(--green);border-radius:100px;transition:width .4s}
.hearts{display:flex;gap:4px}.heart{font-size:20px;transition:transform .2s}.heart.lost{filter:grayscale(1);opacity:.3;transform:scale(.8)}
.lesson-body{flex:1;width:100%;max-width:640px;margin:0 auto;padding:2rem 1.5rem;display:flex;flex-direction:column}
.q-type-label{font-size:13px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--blue);margin-bottom:.75rem}
.q-text{font-size:clamp(18px,3.5vw,24px);font-weight:800;line-height:1.4;margin-bottom:.5rem}
.q-emoji{font-size:56px;text-align:center;margin-bottom:1.25rem}
.choices{display:flex;flex-direction:column;gap:12px;margin-bottom:2rem}
.choice-btn{padding:16px 20px;border-radius:16px;border:2px solid var(--border-d);background:var(--white);font-family:inherit;font-size:16px;font-weight:700;color:var(--ink);cursor:pointer;text-align:left;transition:all .15s;display:flex;align-items:center;gap:12px;box-shadow:0 4px 0 var(--border)}
.choice-btn:not(.disabled):hover{border-color:var(--blue);background:var(--blue-pale);transform:translateX(3px)}
.choice-btn.selected{border-color:var(--blue);background:var(--blue-pale)}
.choice-btn.correct{border-color:var(--green);background:var(--green-pale)}
.choice-btn.wrong{border-color:var(--red);background:var(--red-pale)}
.choice-key{width:34px;height:34px;border-radius:10px;background:var(--border);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0;transition:all .15s}
.choice-btn.selected .choice-key{background:var(--blue);color:var(--card)}
.choice-btn.correct .choice-key{background:var(--green);color:var(--card)}
.choice-btn.wrong .choice-key{background:var(--red);color:var(--card)}
.typed-wrap{margin-bottom:2rem}
.typed-input{width:100%;padding:16px 20px;border:2px solid var(--border-d);border-radius:16px;font-family:inherit;font-size:20px;font-weight:700;outline:none;background:var(--white);color:var(--ink);box-shadow:0 4px 0 var(--border)}
.typed-input:focus{border-color:var(--blue)}
.typed-input.correct{border-color:var(--green);background:var(--green-pale)}
.typed-input.wrong{border-color:var(--red);background:var(--red-pale);animation:shake .3s}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
.feedback-banner{border-radius:16px;padding:1.25rem 1.5rem;margin-bottom:1.5rem;display:flex;align-items:flex-start;gap:12px;animation:slideUp .25s ease}
@keyframes slideUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.feedback-banner.correct{background:var(--green-pale);border:2px solid var(--green)}
.feedback-banner.wrong{background:var(--red-pale);border:2px solid var(--red)}
.feedback-banner.maxed{background:var(--orange-pale);border:2px solid var(--orange)}
.fb-icon{font-size:24px;flex-shrink:0;margin-top:1px}.fb-title{font-size:15px;font-weight:800;margin-bottom:2px}.fb-body{font-size:14px;color:var(--ink-soft);line-height:1.5}
.action-row{display:flex;justify-content:flex-end;gap:10px;margin-top:auto;padding-top:1rem}
.attempts-row{display:flex;gap:6px;margin-bottom:1rem}
.attempt-dot{width:10px;height:10px;border-radius:50%;background:var(--border-d)}
.attempt-dot.used{background:var(--red)}.attempt-dot.remaining{background:var(--green)}
.summary-trophy{font-size:80px;text-align:center;margin-bottom:.5rem;animation:pop .4s}
@keyframes pop{0%{transform:scale(0)}80%{transform:scale(1.15)}100%{transform:scale(1)}}
.summary-title{font-size:clamp(26px,5vw,38px);font-weight:900;text-align:center;margin-bottom:.5rem}
.summary-sub{font-size:16px;color:var(--ink-soft);text-align:center;margin-bottom:2rem}
.summary-stats{display:flex;gap:12px;margin-bottom:2rem;flex-wrap:wrap;justify-content:center}
.summary-stat{background:var(--white);border:2px solid var(--border);border-radius:16px;padding:1rem 1.5rem;text-align:center;min-width:100px;box-shadow:0 4px 0 var(--border)}
.summary-stat-num{font-size:28px;font-weight:900}
.summary-stat-label{font-size:12px;font-weight:700;color:var(--ink-muted);letter-spacing:.04em;text-transform:uppercase}
.summary-breakdown{width:100%;max-width:440px;background:var(--white);border:2px solid var(--border);border-radius:24px;padding:1.25rem;margin-bottom:2rem;box-shadow:0 4px 0 var(--border)}
.sb-title{font-size:14px;font-weight:800;color:var(--ink-muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.75rem}
.sb-row{display:flex;align-items:center;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid var(--border);font-size:14px}
.sb-row:last-child{border-bottom:none}
.sb-q{font-weight:600;flex:1;margin-right:1rem}
.sb-result{font-weight:800;font-size:13px;padding:3px 10px;border-radius:100px}
.sb-correct{background:var(--green-pale);color:var(--green)}.sb-wrong{background:var(--red-pale);color:var(--red-d)}
.summary-btns{display:flex;flex-direction:column;gap:10px;width:100%;max-width:340px}
.theme-switcher{position:fixed;right:20px;bottom:20px;z-index:1000;display:flex;gap:8px;padding:8px;background:var(--card);border:2px solid var(--border);border-radius:999px;box-shadow:0 4px 0 var(--border)}
.theme-switcher button{width:38px;height:38px;border:2px solid var(--border);border-radius:50%;background:var(--bg);cursor:pointer;font-size:17px;transition:transform .15s}
.theme-switcher button:hover{transform:translateY(-2px)}
.theme-switcher button.active-theme{border-color:var(--accent);box-shadow:0 0 0 3px var(--orange-pale)}
.toast{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%) translateY(100px);background:var(--ink);color:var(--card);padding:12px 24px;border-radius:100px;font-size:15px;font-weight:700;z-index:9999;transition:transform .35s;white-space:nowrap;pointer-events:none}
.toast.show{transform:translateX(-50%) translateY(0)}
@media(max-width:500px){.summary-stats{gap:8px}.summary-stat{padding:.75rem 1rem;min-width:80px}}
</style>
</head>
<body>
<div class="toast" id="toast"></div>
<div class="theme-switcher">
  <button type="button" onclick="setTheme('forest')" data-theme-choice="forest" title="Forest">🌿</button>
  <button type="button" onclick="setTheme('ink')" data-theme-choice="ink" title="Ink">🖋️</button>
  <button type="button" onclick="setTheme('neon')" data-theme-choice="neon" title="Neon">💡</button>
</div>

<!-- ONBOARDING -->
<div class="screen" id="screen-onboard">
  <div class="onboard-logo">🦉</div>
  <h1 class="onboard-title">Welcome to<br><em>Learnova!</em></h1>
  <p class="onboard-sub">Learn math, reading & science — one fun lesson at a time.</p>
  <div class="name-input-wrap">
    <label for="nameInput">What's your name?</label>
    <input class="name-input" id="nameInput" type="text" placeholder="Your first name..." maxlength="24" autocomplete="off">
    <label for="avatarSelect">Choose your avatar</label>
    <select class="avatar-select" id="avatarSelect">
      <option value="🦊">🦊 Fox</option>
      <option value="🦉">🦉 Owl</option>
      <option value="🐻">🐻 Bear</option>
      <option value="🐸">🐸 Frog</option>
      <option value="🐧">🐧 Penguin</option>
      <option value="⭐">⭐ Star</option>
    </select>
  </div>
  <button class="btn btn-green btn-lg" onclick="startJourney()">Let's Go! 🚀</button>
</div>

<!-- MAP -->
<div class="screen" id="screen-map">
  <div class="map-header">
    <div class="map-logo">Learn<span>ova</span></div>
    <div style="display:flex;gap:8px;align-items:center">
      <div class="streak-badge">🔥 <span id="streakNum">0</span></div>
      <div class="xp-badge">⭐ <span id="xpNum">0</span> XP</div>
    </div>
  </div>
  <div class="map-body" id="mapBody"></div>
</div>

<!-- LESSON -->
<div class="screen" id="screen-lesson">
  <div class="lesson-topbar">
    <button class="back-btn" onclick="goToMap()" title="Back to map">✕</button>
    <div class="progress-bar-outer"><div class="progress-bar-inner" id="progressBar" style="width:0%"></div></div>
    <div class="hearts" id="heartsDisplay"></div>
  </div>
  <div class="lesson-body" id="lessonBody"></div>
</div>

<!-- SUMMARY -->
<div class="screen" id="screen-summary">
  <div class="summary-trophy" id="summaryTrophy">🏆</div>
  <div class="summary-title" id="summaryTitle">Lesson Complete!</div>
  <div class="summary-sub" id="summarySub"></div>
  <div class="summary-stats" id="summaryStats"></div>
  <div class="summary-breakdown" id="summaryBreakdown"></div>
  <div class="summary-btns">
    <button class="btn btn-green btn-lg" onclick="goToMap()">Continue 🗺️</button>
    <button class="btn btn-outline btn-lg" onclick="downloadSummary()">📄 Export Summary JSON</button>
  </div>
</div>

<script>
