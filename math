function showScreen(id){document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"));document.getElementById("screen-"+id).classList.add("active");}

function boot(){
  loadTheme();
  loadState();
  if(!state){showScreen("onboard");return;}
  updateStreak();
  showScreen("map");
  renderMap();
}

// ── ONBOARDING ────────────────────────────────────────
document.getElementById("nameInput").addEventListener("keydown",e=>{if(e.key==="Enter")startJourney();});
function startJourney(){
  const name=document.getElementById("nameInput").value.trim();
  if(!name){toast("Please enter your name! 😊");return;}
  const av=document.getElementById("avatarSelect").value;
  localStorage.setItem("ln_avatar",av);
  initState(name);
  updateStreak();
  showScreen("map");
  renderMap();
}

// ── STREAK ────────────────────────────────────────────
function updateStreak(){
  if(!state)return;
  const today=new Date().toDateString();
  if(state.lastDate!==today){
    const yest=new Date();yest.setDate(yest.getDate()-1);
    if(state.lastDate===yest.toDateString())state.streak=(state.streak||0)+1;
    else if(!state.lastDate)state.streak=0;
    state.lastDate=today;
    saveState();
  }
}

// ── MAP ───────────────────────────────────────────────
function renderMap(){
  document.getElementById("streakNum").textContent=state.streak||0;
  document.getElementById("xpNum").textContent=state.xp||0;
  const body=document.getElementById("mapBody");
  body.innerHTML=`<div class="profile-header">
    <div class="avatar">${getAvatar()}</div>
    <div class="profile-text"><h2>Hi, ${state.name}! 👋</h2><p>Grade 3 Math Path</p></div>
  </div>`;

  CURRICULUM.units.forEach((unit,ui)=>{
    // Unit header
    const uh=document.createElement("div");
    uh.className="unit-header-card";
    uh.style.background=ui%2===0?"var(--primary)":"var(--secondary)";
    uh.style.boxShadow=`0 6px 0 ${ui%2===0?"var(--primary-dark)":"var(--secondary-dark)"}`;
    uh.innerHTML=`<h2>Unit ${ui+1}: ${unit.title}</h2><p>${unit.description}</p>`;
    body.appendChild(uh);

    const path=document.createElement("div");
    path.className="map-path";

    unit.lessons.forEach((lesson,li)=>{
      const done=!!state.completedLessons[lesson.id];
      const unlocked=isUnlocked(ui,li);

      if(li>0){
        const conn=document.createElement("div");
        const prevDone=!!state.completedLessons[unit.lessons[li-1].id];
        conn.className="map-connector "+(prevDone?"mc-done":"mc-locked");
        path.appendChild(conn);
      }

      const wrap=document.createElement("div");
      wrap.className="map-node-wrap";

      const node=document.createElement("button");
      node.className=`map-node ${done?"node-done":unlocked?"node-active":"node-locked"}`;
      if(!unlocked)node.classList.add("locked");
      node.textContent=done?"✓":unlocked?lesson.emoji:"🔒";
      if(unlocked||done)node.onclick=()=>startLesson(unit.id,lesson.id);

      const label=document.createElement("div");
      label.className="node-label";
      label.style.color=done?"var(--primary)":unlocked?"var(--secondary)":"var(--ink-muted)";
      label.textContent=lesson.title;

      // Score badge if done
      if(done&&state.completedLessons[lesson.id]){
        const sc=state.completedLessons[lesson.id];
        const badge=document.createElement("div");
        badge.style.cssText="font-size:11px;font-weight:700;color:var(--primary);margin-top:3px;opacity:.7;";
        badge.textContent=`${sc.accuracy}%`;
        wrap.appendChild(node);
        wrap.appendChild(label);
        wrap.appendChild(badge);
      } else {
        wrap.appendChild(node);
        wrap.appendChild(label);
      }
      path.appendChild(wrap);
    });

    body.appendChild(path);

    if(allUnitDone(ui)){
      const banner=document.createElement("div");
      banner.className="unit-complete-banner";
      banner.style.background="var(--gold)";
      banner.style.boxShadow="0 6px 0 var(--accent-dark)";
      banner.innerHTML=`<h3>🎉 Unit ${ui+1} Complete!</h3><p>All lessons mastered.</p>
        <button class="btn btn-outline" style="margin:0 auto;display:flex" onclick="showUnitSummary('${unit.id}')">📊 View Summary</button>`;
      body.appendChild(banner);
    }

    const sp=document.createElement("div");sp.style.height="2rem";body.appendChild(sp);
  });
}

// ── LESSON ────────────────────────────────────────────
function startLesson(unitId,lessonId){
  const unit=CURRICULUM.units.find(u=>u.id===unitId);
  if(!unit)return;
  const lesson=unit.lessons.find(l=>l.id===lessonId);
  if(!lesson)return;
  session={unitId,lessonId,qIndex:0,attempts:0,hearts:3,results:[],answered:false,selectedChoice:null};
  showScreen("lesson");
  renderQuestion(lesson);
}

function getLessonData(){
  const unit=CURRICULUM.units.find(u=>u.id===session.unitId);
  return unit?unit.lessons.find(l=>l.id===session.lessonId):null;
}

function goToMap(){showScreen("map");renderMap();}

function renderHearts(){
  const el=document.getElementById("heartsDisplay");
  el.innerHTML="";
  for(let i=0;i<3;i++){
    const h=document.createElement("span");
    h.className="heart"+(i>=session.hearts?" lost":"");
    h.textContent="❤️";
    el.appendChild(h);
  }
}

function renderQuestion(lesson){
  const q=lesson.questions[session.qIndex];
  const total=lesson.questions.length;
  document.getElementById("progressBar").style.width=(session.qIndex/total*100)+"%";
  renderHearts();
  session.answered=false;
  session.selectedChoice=null;
  session.attempts=0;

  const body=document.getElementById("lessonBody");
  body.innerHTML="";

  const typeLabel=document.createElement("div");
  typeLabel.className="q-type-label";
  typeLabel.textContent=q.type==="mcq"?"Choose the correct answer":"Type your answer";
  body.appendChild(typeLabel);

  if(q.emoji){
    const em=document.createElement("div");em.className="q-emoji";em.textContent=q.emoji;body.appendChild(em);
  }

  const qt=document.createElement("div");qt.className="q-text";qt.textContent=q.text;body.appendChild(qt);

  // Attempt dots
  const attRow=document.createElement("div");
  attRow.className="attempts-row";attRow.id="attemptsRow";
  for(let i=0;i<3;i++){const d=document.createElement("div");d.className="attempt-dot remaining";attRow.appendChild(d);}
  body.appendChild(attRow);

  const fb=document.createElement("div");fb.id="feedbackArea";body.appendChild(fb);

  if(q.type==="mcq")renderMCQ(q,body);else renderTyped(q,body);
}

function renderMCQ(q,body){
  const wrap=document.createElement("div");wrap.className="choices";
  const keys=["A","B","C","D"];
  q.choices.forEach((c,i)=>{
    const btn=document.createElement("button");
    btn.className="choice-btn";
    btn.innerHTML=`<span class="choice-key">${keys[i]||i+1}</span>${c}`;
    btn.onclick=()=>selectChoice(i);
    wrap.appendChild(btn);
  });
  body.appendChild(wrap);
  const ar=document.createElement("div");ar.className="action-row";ar.id="actionRow";
  const cb=document.createElement("button");cb.className="btn btn-green btn-disabled";cb.id="checkBtn";cb.textContent="Check ✓";cb.onclick=()=>submitMCQ(q);
  ar.appendChild(cb);body.appendChild(ar);
}

function selectChoice(idx){
  if(session.answered)return;
  session.selectedChoice=idx;
  document.querySelectorAll(".choice-btn").forEach((b,i)=>b.classList.toggle("selected",i===idx));
  const cb=document.getElementById("checkBtn");
  if(cb)cb.classList.remove("btn-disabled");
}

function renderTyped(q,body){
  const wrap=document.createElement("div");wrap.className="typed-wrap";
  const inp=document.createElement("input");
  inp.className="typed-input";inp.id="typedInput";inp.type="text";
  inp.placeholder="Type your answer here...";inp.autocomplete="off";
  inp.addEventListener("keydown",e=>{if(e.key==="Enter")submitTyped(q);});
  wrap.appendChild(inp);body.appendChild(wrap);
  const ar=document.createElement("div");ar.className="action-row";ar.id="actionRow";
  const cb=document.createElement("button");cb.className="btn btn-blue";cb.textContent="Check ✓";cb.onclick=()=>submitTyped(q);
  ar.appendChild(cb);body.appendChild(ar);
  setTimeout(()=>inp.focus(),50);
}

function submitMCQ(q){
  if(session.answered||session.selectedChoice===null)return;
  const correct=session.selectedChoice===q.answer;
  // Mark choices visually first
  document.querySelectorAll(".choice-btn").forEach((b,i)=>{
    if(i===q.answer)b.classList.add("correct");
    else if(i===session.selectedChoice&&!correct)b.classList.add("wrong");
    b.classList.add("disabled");b.onclick=null;
  });
  handleAnswer(correct,q,String(session.selectedChoice));
}

function submitTyped(q){
  if(session.answered)return;
  const inp=document.getElementById("typedInput");
  if(!inp)return;
  const val=inp.value.trim();
  if(!val){toast("Type something first! ✏️");return;}
  const correct=normalizeAnswer(val)===normalizeAnswer(q.answer);
  if(correct){inp.classList.add("correct");}
  else{inp.classList.add("wrong");setTimeout(()=>{if(inp)inp.classList.remove("wrong");},400);}
  handleAnswer(correct,q,val);
  if(correct||session.attempts>=2)inp.disabled=true; // disable after correct or last attempt
}

function handleAnswer(correct,q,given){
  session.attempts++;
  updateAttemptDots();
  if(correct){
    session.answered=true;
    session.results.push({correct:true,attempts:session.attempts,answerGiven:given,question:q.text,correctAnswer:String(q.answer)});
    showFeedback("correct","🎉 Correct!","");
    replaceCheckWithNext();
  } else if(session.attempts>=3){
    session.answered=true;
    session.hearts=Math.max(0,session.hearts-1);
    renderHearts();
    session.results.push({correct:false,attempts:session.attempts,answerGiven:given,question:q.text,correctAnswer:String(q.answer)});
    const correctText=q.type==="mcq"?q.choices[q.answer]:q.answer;
    showFeedback("maxed","😬 Nice try!",`The correct answer was: <strong>${correctText}</strong>`);
    replaceCheckWithNext();
  } else {
    session.hearts=Math.max(0,session.hearts-1);
    renderHearts();
    showFeedback("wrong","Not quite! 🤔",q.hint?`Hint: ${q.hint}`:`Try again! ${3-session.attempts} attempt${3-session.attempts!==1?"s":""} left.`);
    if(q.type==="mcq"){
      session.selectedChoice=null;
      document.querySelectorAll(".choice-btn").forEach(b=>{
        b.classList.remove("selected","correct","wrong","disabled");
        b.onclick=(_i=>()=>selectChoice(_i))(Array.from(document.querySelectorAll(".choice-btn")).indexOf(b));
      });
      // Re-attach onclick properly
      document.querySelectorAll(".choice-btn").forEach((b,i)=>{b.onclick=()=>selectChoice(i);});
      const cb=document.getElementById("checkBtn");if(cb)cb.classList.add("btn-disabled");
    } else {
      const inp=document.getElementById("typedInput");
      if(inp){inp.disabled=false;inp.value="";inp.focus();}
    }
  }
}

function updateAttemptDots(){
  document.querySelectorAll("#attemptsRow .attempt-dot").forEach((d,i)=>{
    d.className="attempt-dot "+(i<session.attempts?"used":"remaining");
  });
}

function showFeedback(type,title,msg){
  const area=document.getElementById("feedbackArea");
  if(!area)return;
  const icons={correct:"✅",wrong:"❌",maxed:"💡"};
  area.innerHTML=`<div class="feedback-banner ${type}"><span class="fb-icon">${icons[type]}</span><div><div class="fb-title">${title}</div><div class="fb-body">${msg}</div></div></div>`;
}

function replaceCheckWithNext(){
  const ar=document.getElementById("actionRow");if(!ar)return;
  const lesson=getLessonData();if(!lesson)return;
  const isLast=session.qIndex>=lesson.questions.length-1;
  ar.innerHTML="";
  const btn=document.createElement("button");
  btn.className="btn btn-green";
  btn.textContent=isLast?"Finish 🏁":"Next →";
  btn.onclick=isLast?finishLesson:nextQuestion;
  ar.appendChild(btn);
}

function nextQuestion(){session.qIndex++;renderQuestion(getLessonData());}

// ── FINISH ────────────────────────────────────────────
function finishLesson(){
  const lesson=getLessonData();
  const unit=CURRICULUM.units.find(u=>u.id===session.unitId);
  if(!lesson||!unit)return;
  const correct=session.results.filter(r=>r.correct).length;
  const total=session.results.length;
  const accuracy=total>0?Math.round((correct/total)*100):0;
  const xpEarned=Math.round((lesson.xp||20)*(accuracy/100));

  state.completedLessons[lesson.id]={score:correct,total,accuracy,xpEarned,date:new Date().toLocaleDateString()};
  state.xp=(state.xp||0)+xpEarned;
  updateStreak();
  if(allUnitDone(CURRICULUM.units.indexOf(unit)))buildUnitSummary(unit);
  saveState();
  showSummaryScreen(lesson,unit,correct,total,accuracy,xpEarned);
}

function buildUnitSummary(unit){
  const s={unitId:unit.id,unitTitle:unit.title,student:state.name,completedDate:new Date().toLocaleDateString(),
    lessons:unit.lessons.map(l=>{const r=state.completedLessons[l.id]||{};return{lessonId:l.id,title:l.title,...r};}),
    totalXP:unit.lessons.reduce((a,l)=>a+(state.completedLessons[l.id]?.xpEarned||0),0),
    averageAccuracy:Math.round(unit.lessons.reduce((a,l)=>a+(state.completedLessons[l.id]?.accuracy||0),0)/unit.lessons.length)
  };
  if(!state.summaries)state.summaries=[];
  const idx=state.summaries.findIndex(x=>x.unitId===unit.id);
  idx>=0?state.summaries[idx]=s:state.summaries.push(s);
}

function showSummaryScreen(lesson,unit,correct,total,accuracy,xpEarned){
  const mood=accuracy===100?"excited":accuracy>=70?"happy":accuracy>=50?"neutral":"coach";
  const moodCopy={excited:"Perfect score — you crushed it!",happy:"Great work, keep it up!",neutral:"Good effort. A little review will help.",coach:"No stress. Let's slow down and practice."};
  const trophy=mood==="excited"?"🏆":mood==="happy"?"⭐":mood==="neutral"?"📘":"💡";
  const title=mood==="excited"?"Amazing Score!":mood==="happy"?"Great Work!":mood==="neutral"?"Lesson Done!":"Keep Practicing!";
  document.getElementById("summaryTrophy").textContent=trophy;
  document.getElementById("summaryTitle").textContent=title;
  document.getElementById("summarySub").textContent=`${lesson.title} — ${moodCopy[mood]}`;
  document.getElementById("summaryStats").innerHTML=`
    <div class="summary-stat"><div class="summary-stat-num">${correct}/${total}</div><div class="summary-stat-label">Correct</div></div>
    <div class="summary-stat"><div class="summary-stat-num">${accuracy}%</div><div class="summary-stat-label">Accuracy</div></div>
    <div class="summary-stat"><div class="summary-stat-num">+${xpEarned}</div><div class="summary-stat-label">XP Earned</div></div>`;
  let bd=`<div class="sb-title">Question Breakdown</div>`;
  session.results.forEach((r,i)=>{
    const q=r.question.length>40?r.question.slice(0,40)+"…":r.question;
    bd+=`<div class="sb-row"><div class="sb-q">Q${i+1}: ${q}</div><span class="sb-result ${r.correct?"sb-correct":"sb-wrong"}">${r.correct?"✓ Correct":"✗ Wrong"}</span></div>`;
  });
  document.getElementById("summaryBreakdown").innerHTML=bd;
  window._lastSummaryExport={student:state.name,lessonId:lesson.id,lessonTitle:lesson.title,unitTitle:unit.title,date:new Date().toLocaleDateString(),score:correct,total,accuracy,xpEarned,breakdown:session.results};
  showScreen("summary");
}

function downloadSummary(){
  const data=window._lastSummaryExport||{};
  const blob=new Blob([JSON.stringify(data,null,2)],{type:"application/json"});
  const a=document.createElement("a");a.href=URL.createObjectURL(blob);
  a.download=`learnova_${(data.lessonId||"summary")}.json`;a.click();
  toast("Summary exported! 📄");
}

function showUnitSummary(unitId){
  if(!state.summaries){toast("No summary yet!");return;}
  const s=state.summaries.find(x=>x.unitId===unitId);
  if(!s){toast("No summary yet!");return;}
  window._lastSummaryExport=s;downloadSummary();
}

// ── TOAST ─────────────────────────────────────────────
let _tt=null;
function toast(msg){
  const el=document.getElementById("toast");el.textContent=msg;el.classList.add("show");
  if(_tt)clearTimeout(_tt);_tt=setTimeout(()=>el.classList.remove("show"),2500);
}

boot();
</script>
</body>
