// ── STATE & PROGRESS ──────────────────────────────────
const SK="learnova_g3_v2";
let state=null,session={lessonId:null,unitId:null,qIndex:0,attempts:0,hearts:3,results:[],answered:false,selectedChoice:null};

function loadState(){try{state=JSON.parse(localStorage.getItem(SK));}catch(e){state=null;}}
function saveState(){localStorage.setItem(SK,JSON.stringify(state));}
function initState(name){
  state={name,xp:0,streak:0,lastDate:null,completedLessons:{}};
  saveState();
}

// FIX 2: Unlock logic — first lesson of first unit always unlocked
function isUnlocked(unitIdx,lessonIdx){
  if(unitIdx===0&&lessonIdx===0)return true;
  if(lessonIdx===0){
    // first lesson of later unit: all prev unit lessons done
    return CURRICULUM.units[unitIdx-1].lessons.every(l=>!!state.completedLessons[l.id]);
  }
  // subsequent lessons: previous lesson done
  const prevId=CURRICULUM.units[unitIdx].lessons[lessonIdx-1].id;
  return !!state.completedLessons[prevId];
}

function allUnitDone(ui){
  const u=CURRICULUM.units[ui];
  return u&&u.lessons.every(l=>!!state.completedLessons[l.id]);
}

